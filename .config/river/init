#!/usr/bin/env sh

# ====== Autostart =======
pidof -q waybar || riverctl spawn waybar
pidof -q kanshi || riverctl spawn kanshi # Manage outputs dynamically
pidof -q kdeconnectd || riverctl spawn kdeconnectd

riverctl spawn "foot --server"
riverctl spawn /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
# riverctl spawn /usr/lib/xdg-desktop-portal-hyprland
# riverctl spawn "/usr/lib/xdg-desktop-portal-termfilechooser -r"
riverctl spawn mako

# ====== Command/Application bindings =======
riverctl map normal Super Escape spawn "footclient tmux"
riverctl map normal Super+Shift Escape spawn "foot"
riverctl map normal Super Return spawn "fuzzel --no-icons"
riverctl map normal Super+Shift Q spawn "power-options"
riverctl map normal Super B spawn "librewolf -P default"
riverctl map normal Super+Shift B spawn "librewolf -P alt"
riverctl map normal Super G spawn "pidof -q gammastep && pkill gammastep || gammastep -O 3000"
riverctl map normal Super E spawn "footclient yazi"
riverctl map normal Super W spawn "footclient nvim todo"
riverctl map normal Super S spawn "~/.config/river/init"
riverctl map normal Super N spawn "makoctl restore"
riverctl map normal Super+Shift N spawn "makoctl dismiss"
riverctl map normal Super M spawn "footclient tmux attach-session -t alot"

riverctl map normal Super P	spawn "screenshot"			# screenshot selection
riverctl map normal Super+Shift P spawn "screenshot -f" # screenshot whole screen

# ====== Window bindings ======
riverctl map normal Super Q close
riverctl map normal Super F toggle-fullscreen

riverctl map normal Super J focus-view next
riverctl map normal Super K focus-view previous
riverctl map normal Super+Shift J swap next
riverctl map normal Super+Shift K swap previous

riverctl map normal Super Space focus-output next
riverctl map normal Super+Shift Space send-to-output next

riverctl map normal Super Z zoom

riverctl map normal Super H send-layout-cmd rivertile "main-ratio -0.05"
riverctl map normal Super L send-layout-cmd rivertile "main-ratio +0.05"
riverctl map normal Super Minus send-layout-cmd rivertile "main-count -1"
riverctl map normal Super Plus send-layout-cmd rivertile "main-count +1"

# ====== Floating bindings =======
riverctl map-pointer float Super BTN_MIDDLE toggle-float
riverctl map float Super T toggle-float
riverctl map normal Super T toggle-float

# Move floating windows
riverctl map normal Super Y move left 100
riverctl map normal Super U move down 100
riverctl map normal Super I move up 100
riverctl map normal Super O move right 100
riverctl map-pointer normal Super BTN_LEFT move-view
# Resize floating windows
riverctl map normal Super+Shift Y resize horizontal -100
riverctl map normal Super+Shift U resize vertical -100
riverctl map normal Super+Shift I resize vertical 100
riverctl map normal Super+Shift O resize horizontal 100
riverctl map-normal normal Super+Shift BTN_RIGHT resize-view

# ====== Tags =======
for i in $(seq 1 9)
do
    tags=$((1 << ($i - 1)))

    # Super+[1-9] to focus tag [0-8]
    riverctl map normal Super $i set-focused-tags $tags

    # Super+Shift+[1-9] to tag focused view with tag [0-8]
    riverctl map normal Super+Shift $i set-view-tags $tags

    # Super+Control+[1-9] to toggle focus of tag [0-8]
    riverctl map normal Super+Control $i toggle-focused-tags $tags

    # Super+Shift+Control+[1-9] to toggle tag [0-8] of focused view
    riverctl map normal Super+Shift+Control $i toggle-view-tags $tags
done

# Super+0 to focus all tags
# Super+Shift+0 to tag focused view with all tags
all_tags=$(((1 << 32) - 1))
riverctl map normal Super 0 set-focused-tags $all_tags
riverctl map normal Super+Shift 0 set-view-tags $all_tags


# Declare a passthrough mode. This is useful for using virtual machines
riverctl declare-mode passthrough

# Super+F9 to toggle passthrough mode
riverctl map normal Super F9 enter-mode passthrough
riverctl map passthrough Super F9 enter-mode normal

# Various media key mapping examples for both normal and locked mode which do
# not have a modifier
for mode in normal locked
do
    # Control pulse audio volume with pamixer (https://github.com/cdemoulins/pamixer)
    riverctl map -repeat $mode None XF86AudioRaiseVolume  spawn 'volume up'
    riverctl map -repeat $mode None XF86AudioLowerVolume  spawn 'volume down'
    riverctl map $mode None XF86AudioMute spawn 'volume muted'

    # Control MPRIS aware media players with playerctl (https://github.com/altdesktop/playerctl)
    riverctl map $mode None XF86AudioMedia spawn 'playerctl play-pause'
    riverctl map $mode None XF86AudioPlay  spawn 'playerctl play-pause'
    riverctl map $mode None XF86AudioPrev  spawn 'playerctl previous'
    riverctl map $mode None XF86AudioNext  spawn 'playerctl next'

    # Control screen backlight brightness with brightnessctl (https://github.com/Hummer12007/brightnessctl)
    riverctl map -repeat $mode None XF86MonBrightnessUp   spawn 'brightnessctl set +10%'
    riverctl map -repeat $mode None XF86MonBrightnessDown spawn 'brightnessctl set 10%-'
done

# ====== Inputs ======
riverctl focus-follows-cursor normal
riverctl set-cursor-warp on-focus-change
riverctl hide-cursor when-typing enabled
riverctl input pointer-1739-52876-VEN_06CB:00_06CB:CE8C_Touchpad natural-scroll enabled
riverctl input pointer-1739-52876-VEN_06CB:00_06CB:CE8C_Touchpad tap enabled
riverctl input pointer-1739-52876-VEN_06CB:00_06CB:CE8C_Touchpad pointer-accel 0.7
riverctl input pointer-1739-52876-VEN_06CB:00_06CB:CE8C_Touchpad accel-profile adaptive

riverctl keyboard-layout gb

riverctl set-repeat 50 300 # Set keyboard repeat rate

# ======= Outputs =======
# Set background image
swaybg -m fill -i ~/onedrive/pictures/carnotaurus.jpg &

# Configure borders
riverctl border-color-focused 0x98971A
riverctl border-color-unfocused 0x666666
riverctl border-width 1

# ======== Rules =========
# Make all views with an app-id that starts with "float" and title "foo" start floating.
# riverctl rule-add -app-id 'float*' -title 'foo' float

# Make all views with app-id "bar" and any title use client-side decorations
# riverctl rule-add -app-id "bar" csd

# Make all windows use server-side decorations
riverctl rule-add -title "*" ssd

# Rules for popup filepicker (from xdg-desktop-portal-termfilechooser)
riverctl rule-add -title "filepicker" float
riverctl rule-add -title "filepicker" dimensions 1250 750

# ======== Layout =========
# Set the default layout generator to be rivertile and start it.
# River will send the process group of the init executable SIGTERM on exit.
riverctl default-layout rivertile
rivertile -view-padding 0 -outer-padding 0 -main-ratio 0.55 &

systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=river
systemctl --user restart xdg-desktop-portal
